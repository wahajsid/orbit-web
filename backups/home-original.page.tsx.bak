];

const IMPACT: { num: string; label: string; petrol?: boolean }[] = [
  { num: "2 days", label: "the month-end close, down from nine" },
  { num: "100%", label: "of lines tax-tested against FTA & ZATCA rules", petrol: true },
  { num: "13 weeks", label: "of rolling cash visibility, refreshed nightly" },
  { num: "38", label: "documents posted in a single night, untouched" },
  { num: "6", label: "accounting systems Orbit posts straight into", petrol: true },
