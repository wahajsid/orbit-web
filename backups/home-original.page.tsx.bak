];

const STEPS: [string, string, string][] = [
  ["01", "Claim a seat", "Your founding invite lands by email; the workspace is live in minutes. No implementation project, no consultants."],
  ["02", "Bring your books", "Connect Zoho Books, Xero, QuickBooks, Odoo, Wafeq or ERPNext — or skip setup entirely and just forward documents by email or WhatsApp."],
  ["03", "Verify once, then it flows", "Confirm your channel and anything you send files itself: read, coded from your own history, tax-tested, matched to POs and bank lines, posted."],
  ["04", "Run the morning, not the month", "One brief at sunrise: what happened yesterday, the few things that need you today. Nothing posts silently past the thresholds you set — the judgement calls always wait for a human."],
];

const GULF: [string, string, string][] = [
  ["FTA-READY", "UAE VAT & Corporate Tax built in", "5% input-VAT testing on every line, 9% CT accrual, and a one-click FTA audit-response assembler."],
  ["ZATCA-AWARE", "KSA from day one", "15% VAT rules and e-invoice clearance status tracked; Saudi entities aren't an afterthought."],
  ["AED · SAR", "Native to Gulf money", "Multi-entity across the UAE and Saudi, in the currencies your board actually reads."],
